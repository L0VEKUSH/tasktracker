# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/task-tracker?retryWrites=true&w=majority

# Port the Express server listens on
PORT=5000

# JWT Secret — use a long random string, never use the default in production
JWT_SECRET=your_super_secret_jwt_key_here

# Node environment: development | production
NODE_ENV=development

# URL of the deployed/local frontend, used for CORS
CLIENT_URL=http://localhost:5173
